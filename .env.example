# Server
NODE_ENV=development
PORT=4000
# localhost:3000/3001 are always allowed (see STATIC_DEV_ORIGINS in src/app.ts) — this is
# for deployed frontend origin(s) only, comma-separated
CORS_ORIGIN=https://your-frontend.vercel.app

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ctgbites

# JWT
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Resend
RESEND_API_KEY=
EMAIL_FROM="CTG Bites <orders@ctgbites.com>"
EMAIL_ORDER_STATUS_UPDATES=false
EMAIL_ON_ADD_TO_CART=false

# Cloudinary — if sharing one Cloudinary account across multiple projects,
# CLOUDINARY_FOLDER namespaces this project's uploads under their own folder
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=ctg-bites

# bKash (leave blank/commented until sandbox credentials supplied — feature auto-disables)
# BKASH_APP_KEY=
# BKASH_APP_SECRET=
# BKASH_USERNAME=
# BKASH_PASSWORD=
# BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# Stripe (leave blank/commented until credentials supplied — feature auto-disables)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=

# Seed script — first Owner account
DEFAULT_OWNER_EMAIL=
DEFAULT_OWNER_PASSWORD=
DEFAULT_OWNER_NAME=
